# ============================================
# VIB (Vulnerability in a Box) Configuration
# ============================================
# Copy this file to .env and customize values
# ============================================

# ==================== Grafana ====================
# Leave empty or CHANGE_ME to auto-generate secure password on install
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_PORT=3001

# ==================== VictoriaMetrics ====================
VICTORIAMETRICS_PORT=8429
VICTORIAMETRICS_RETENTION=90d

# ==================== Scanner ====================
# How often to run a full scan (hours)
SCAN_INTERVAL_HOURS=6
# Run a scan immediately on container start
SCAN_ON_STARTUP=true
# Severities to include: UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL
SEVERITY_FILTER=UNKNOWN,LOW,MEDIUM,HIGH,CRITICAL
# Only report vulnerabilities that have a fix available
IGNORE_UNFIXED=false
# Trivy scan timeout per image (seconds)
TRIVY_TIMEOUT=300
# Comma-separated list of additional images to scan (beyond running containers)
# ADDITIONAL_IMAGES=nginx:latest,redis:7,postgres:16

# ==================== Remote Docker (Optional) ====================
# Point VIB at a remote Docker daemon instead of the local socket.
# When set, remove the /var/run/docker.sock volume mount from docker-compose.yml.
# Use with docker-socket-proxy for filtered, read-only remote access.
# DOCKER_HOST=tcp://192.168.1.25:2375

# ==================== AIB Integration (Optional) ====================
# Feed critical/high findings into the AIB asset graph
# AIB_BASE_URL=http://aib:8080
# AIB_API_TOKEN=your-aib-api-token
